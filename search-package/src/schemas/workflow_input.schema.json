{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["user_command", "history_context"],
  "properties": {
    "user_command": { "type": "string" },
    "history_context": {},
    "options": {
      "type": "object",
      "properties": {
        "max_iterations": { "type": "number", "minimum": 1, "maximum": 3 },
        "top_k_eval": { "type": "number", "minimum": 1 },
        "strictness": { "enum": ["strict", "balanced", "loose"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
