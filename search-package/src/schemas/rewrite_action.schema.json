{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["mode", "add_terms", "remove_terms", "replace_map", "adjust_filters"],
  "properties": {
    "mode": { "enum": ["tighten", "broaden", "replace_ambiguous_terms", "rebalance"] },
    "add_terms": { "type": "array", "items": { "type": "string" } },
    "remove_terms": { "type": "array", "items": { "type": "string" } },
    "replace_map": { "type": "object", "additionalProperties": { "type": "string" } },
    "adjust_filters": { "type": "object" }
  }
}
